<UserControl x:Class="AiMonitorClient.Controls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:AiMonitorClient.Controls"
             x:Name="Root" MinWidth="160">

  <Border Background="{DynamicResource CardBg}"
          BorderBrush="{DynamicResource CardBorder}"
          BorderThickness="1" CornerRadius="14"
          Effect="{StaticResource CardShadow}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="68"/>
      </Grid.RowDefinitions>

      <!-- ── Content ── -->
      <StackPanel Grid.Row="0" Margin="12,12,12,8">

        <!-- Icon + title + live dot -->
        <Grid Margin="0,0,0,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Icon badge -->
          <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                  Background="{Binding IconBadgeBrush, ElementName=Root}">
            <TextBlock Text="{Binding IconLabel, ElementName=Root}"
                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                       Foreground="{Binding AccentBrush, ElementName=Root}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>

          <!-- Title -->
          <TextBlock Grid.Column="1" Margin="8,0,0,0"
                     Text="{Binding Title, ElementName=Root}"
                     FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondary}"
                     VerticalAlignment="Center"/>

          <!-- Live dot -->
          <Ellipse Grid.Column="2" x:Name="LiveDot" Width="6" Height="6"
                   Fill="{Binding AccentBrush, ElementName=Root}"
                   VerticalAlignment="Center">
            <Ellipse.Triggers>
              <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                  <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="LiveDot"
                                     Storyboard.TargetProperty="Opacity"
                                     From="1" To="0.2" Duration="0:0:1"
                                     AutoReverse="True"/>
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </Ellipse.Triggers>
          </Ellipse>
        </Grid>

        <!-- Value -->
        <TextBlock Text="{Binding ValueText, ElementName=Root}"
                   FontFamily="Consolas" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,4,0,0"
                   Foreground="{DynamicResource TextPrimary}"/>

        <!-- Subtitle -->
        <TextBlock Text="{Binding SubtitleText, ElementName=Root}"
                   FontFamily="Consolas" FontSize="9"
                   HorizontalAlignment="Center" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextSubtle}"/>
      </StackPanel>

      <!-- ── Graph (full-bleed, bottom-rounded) ── -->
      <Border Grid.Row="1" CornerRadius="0,0,13,13" ClipToBounds="True">
        <ctrl:LiveGraphControl Values="{Binding HistoryValues, ElementName=Root}"
                               AccentColor="{Binding AccentColor, ElementName=Root}"/>
      </Border>
    </Grid>
  </Border>

</UserControl>
