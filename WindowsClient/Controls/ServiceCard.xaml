<UserControl x:Class="AiMonitorClient.Controls.ServiceCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:AiMonitorClient.Controls"
             x:Name="Root" MinWidth="240">

  <UserControl.Resources>
    <!-- Slim capsule progress bar -->
    <Style x:Key="QueueBar" TargetType="ProgressBar">
      <Setter Property="Height"  Value="6"/>
      <Setter Property="Minimum" Value="0"/>
      <Setter Property="Maximum" Value="10"/>
      <Setter Property="Background" Value="#0DFFFFFF"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Border CornerRadius="3" Background="{TemplateBinding Background}">
              <Border x:Name="PART_Indicator" CornerRadius="3"
                      Background="{TemplateBinding Foreground}"
                      MinWidth="12"
                      HorizontalAlignment="Left"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="Value" Value="0">
                <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Border Background="{DynamicResource CardBg}"
          BorderBrush="{DynamicResource CardBorder}"
          BorderThickness="1" CornerRadius="14"
          Effect="{DynamicResource CardShadow}">

    <!-- Single padded body — matches mac .padding(10) all around -->
    <StackPanel Margin="10,10,10,10">

      <!-- Header: icon + name + url + status -->
      <Grid Margin="0,0,0,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Icon badge -->
        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="8"
                Background="{Binding IconBadgeBrush, ElementName=Root}">
          <TextBlock Text="{Binding IconLabel, ElementName=Root}"
                     FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                     Foreground="{Binding AccentBrush, ElementName=Root}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Service name + URL -->
        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="{Binding ServiceName, ElementName=Root}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimary}"/>
          <TextBlock Text="{Binding ServiceUrl, ElementName=Root}"
                     FontFamily="Consolas" FontSize="9"
                     Foreground="{DynamicResource TextSubtle}"/>
        </StackPanel>

        <!-- Status badge -->
        <Border Grid.Column="2" CornerRadius="10" Padding="8,3"
                Background="{Binding StatusBadgeBg, ElementName=Root}"
                BorderBrush="{Binding StatusBadgeBorder, ElementName=Root}"
                BorderThickness="1" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="StatusDot" Width="6" Height="6"
                     Fill="{Binding StatusDotBrush, ElementName=Root}"
                     VerticalAlignment="Center" Margin="0,0,5,0">
              <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                  <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                      <DoubleAnimation Storyboard.TargetName="StatusDot"
                                       Storyboard.TargetProperty="Opacity"
                                       From="1" To="0.25" Duration="0:0:1"
                                       AutoReverse="True"/>
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Ellipse.Triggers>
            </Ellipse>
            <TextBlock Text="{Binding StatusText, ElementName=Root}"
                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                       Foreground="{Binding StatusDotBrush, ElementName=Root}"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Stats row -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
        <!-- CPU -->
        <StackPanel Margin="0,0,20,0">
          <TextBlock Text="CPU" Style="{DynamicResource MonoSmall}"/>
          <TextBlock x:Name="CpuValueText" Text="{Binding CpuText, ElementName=Root}"
                     FontSize="16" FontWeight="Bold" FontFamily="Consolas" MinWidth="45"
                     Foreground="{DynamicResource TextPrimary}"/>
        </StackPanel>
        <!-- MEM -->
        <StackPanel Margin="0,0,20,0">
          <TextBlock Text="MEM" Style="{DynamicResource MonoSmall}"/>
          <TextBlock Text="{Binding MemText, ElementName=Root}"
                     FontSize="16" FontWeight="Bold" FontFamily="Consolas" MinWidth="70"
                     Foreground="{DynamicResource TextPrimary}"/>
        </StackPanel>
        <!-- Extra (MODELS or QUEUE) -->
        <StackPanel>
          <TextBlock Text="{Binding ExtraLabel, ElementName=Root}"
                     Style="{DynamicResource MonoSmall}"/>
          <TextBlock Text="{Binding ExtraText, ElementName=Root}"
                     FontSize="16" FontWeight="Bold" FontFamily="Consolas" MinWidth="40"
                     Foreground="{DynamicResource TextPrimary}"/>
        </StackPanel>
      </StackPanel>

      <!-- Models strip (Ollama) — fixed height to align with ComfyUI queue section -->
      <Border Height="56" Visibility="{Binding ModelsVisibility, ElementName=Root}"
              Margin="0,0,0,6">
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Height="26" VerticalAlignment="Top">
          <ItemsControl x:Name="ModelsPanel" ItemsSource="{Binding ModelNames, ElementName=Root}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border CornerRadius="12" Padding="8,3" Margin="0,0,5,0"
                        Background="{Binding DataContext.ModelBadgeBg,
                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        BorderBrush="{Binding DataContext.ModelBadgeBorder,
                                     RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        BorderThickness="1">
                  <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="9"
                             Foreground="{Binding AccentBrush, ElementName=Root}"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <!-- Queue bars (ComfyUI only) — fixed height to align with models section -->
      <StackPanel Visibility="{Binding QueueSectionVisibility, ElementName=Root}"
                  Height="56" Margin="0,0,0,6">
        <!-- Running -->
        <Grid Margin="0,0,0,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="22"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Running" FontSize="10"
                     Foreground="{DynamicResource TextSubtle}" VerticalAlignment="Center"/>
          <ProgressBar Grid.Column="1" Style="{DynamicResource QueueBar}"
                       Value="{Binding QueueRunning, ElementName=Root}"
                       Foreground="{Binding AccentBrush, ElementName=Root}"
                       Margin="8,0"/>
          <TextBlock Grid.Column="2" Text="{Binding QueueRunning, ElementName=Root}"
                     FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondary}"
                     HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
        <!-- Pending -->
        <Grid Margin="0,0,0,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="22"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Pending" FontSize="10"
                     Foreground="{DynamicResource TextSubtle}" VerticalAlignment="Center"/>
          <ProgressBar Grid.Column="1" Style="{DynamicResource QueueBar}"
                       Value="{Binding QueuePending, ElementName=Root}"
                       Foreground="{Binding AccentBrush, ElementName=Root}"
                       Opacity="0.55" Margin="8,0"/>
          <TextBlock Grid.Column="2" Text="{Binding QueuePending, ElementName=Root}"
                     FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSubtle}"
                     HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
        <!-- Generating (visible only while a workflow is executing) -->
        <Grid Visibility="{Binding GeneratingBarVisibility, ElementName=Root}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="32"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Generating" FontSize="10"
                     Foreground="{DynamicResource TextSubtle}" VerticalAlignment="Center"/>
          <ProgressBar Grid.Column="1" Style="{DynamicResource QueueBar}"
                       Maximum="1" Value="{Binding GenerationProgress, ElementName=Root}"
                       Foreground="{Binding AccentBrush, ElementName=Root}"
                       Opacity="0.85" Margin="8,0"/>
          <TextBlock Grid.Column="2"
                     FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondary}"
                     HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock.Text>
              <MultiBinding StringFormat="{}{0:P0}">
                <Binding Path="GenerationProgress" ElementName="Root"/>
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
        </Grid>
      </StackPanel>

      <!-- CPU USAGE label — matches mac spacing:4 before graph -->
      <TextBlock Text="CPU USAGE" Style="{DynamicResource MonoSmall}" Margin="0,0,0,4"/>

      <!-- Graph — inside body with 8px corners, matches mac clipShape(cornerRadius:8) -->
      <Border CornerRadius="8" ClipToBounds="True" Height="94" Margin="0,0,0,6">
        <ctrl:LiveGraphControl Values="{Binding HistoryValues, ElementName=Root}"
                               AccentColor="{Binding AccentColor, ElementName=Root}"
                               Grayscale="{Binding Grayscale, ElementName=Root}"/>
      </Border>

      <!-- Action buttons -->
      <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
        <Button x:Name="Btn1" Content="{Binding Btn1Label, ElementName=Root}"
                Style="{DynamicResource ActionBtn}"
                Background="{Binding ActionBtnBg, ElementName=Root}"
                BorderBrush="{Binding ActionBtnBorder, ElementName=Root}"
                Foreground="{Binding AccentBrush, ElementName=Root}"
                Margin="0,0,6,0" Click="Btn1_Click"/>
        <Button x:Name="Btn2" Content="{Binding Btn2Label, ElementName=Root}"
                Style="{DynamicResource ActionBtn}"
                Background="{Binding ActionBtnBg, ElementName=Root}"
                BorderBrush="{Binding ActionBtnBorder, ElementName=Root}"
                Foreground="{Binding AccentBrush, ElementName=Root}"
                Visibility="{Binding Btn2Visibility, ElementName=Root}"
                Click="Btn2_Click"/>
      </StackPanel>

    </StackPanel>
  </Border>

</UserControl>



