<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Window / surface colours ── -->
    <SolidColorBrush x:Key="WindowBg"
                     Color="#0D0D17" />
    <SolidColorBrush x:Key="CardBg"
                     Color="#B81A1A26" />
    <!-- #1A1A26 @72% -->
    <SolidColorBrush x:Key="CardBorder"
                     Color="#14FFFFFF" />
    <SolidColorBrush x:Key="SurfacePanel"
                     Color="#1E1E2A" />
    <SolidColorBrush x:Key="Separator"
                     Color="#14FFFFFF" />

    <!-- ── Text ── -->
    <SolidColorBrush x:Key="TextPrimary"
                     Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="TextSecondary"
                     Color="#AAFFFFFF" />
    <SolidColorBrush x:Key="TextSubtle"
                     Color="#44FFFFFF" />
    <SolidColorBrush x:Key="TextMono"
                     Color="#66FFFFFF" />

    <!-- ── Pastel accents (same in dark + light) ── -->
    <Color x:Key="CpuAccentColor">#8BBFFF</Color>
    <Color x:Key="MemAccentColor">#C494FF</Color>
    <Color x:Key="GpuAccentColor">#85FFC2</Color>
    <Color x:Key="OllamaAccentColor">#FF9955</Color>
    <Color x:Key="ComfyAccentColor">#FF8CBF</Color>
    <Color x:Key="SelfAccentColor">#FFD973</Color>

    <SolidColorBrush x:Key="CpuAccent"
                     Color="{StaticResource CpuAccentColor}" />
    <SolidColorBrush x:Key="MemAccent"
                     Color="{StaticResource MemAccentColor}" />
    <SolidColorBrush x:Key="GpuAccent"
                     Color="{StaticResource GpuAccentColor}" />
    <SolidColorBrush x:Key="OllamaAccent"
                     Color="{StaticResource OllamaAccentColor}" />
    <SolidColorBrush x:Key="ComfyAccent"
                     Color="{StaticResource ComfyAccentColor}" />
    <SolidColorBrush x:Key="SelfAccent"
                     Color="{StaticResource SelfAccentColor}" />

    <!-- ── Status ── -->
    <SolidColorBrush x:Key="OnlineBrush"
                     Color="#4ADE80" />
    <SolidColorBrush x:Key="OfflineBrush"
                     Color="#FF6060" />

    <!-- ── Base styles ── -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily"
                Value="Segoe UI" />
        <Setter Property="TextOptions.TextRenderingMode"
                Value="ClearType" />
    </Style>

    <Style x:Key="SectionLabel"
           TargetType="TextBlock">
        <Setter Property="FontFamily"
                Value="Consolas" />
        <Setter Property="FontSize"
                Value="10" />
        <Setter Property="FontWeight"
                Value="Bold" />
        <Setter Property="Foreground"
                Value="{StaticResource TextSubtle}" />
        <Setter Property="Margin"
                Value="0,0,0,8" />
    </Style>

    <Style x:Key="MonoSmall"
           TargetType="TextBlock">
        <Setter Property="FontFamily"
                Value="Consolas" />
        <Setter Property="FontSize"
                Value="9" />
        <Setter Property="Foreground"
                Value="{StaticResource TextMono}" />
    </Style>

    <Style x:Key="ActionBtn"
           TargetType="Button">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimary}" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="FontFamily"
                Value="Segoe UI" />
        <Setter Property="FontSize"
                Value="10" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
        <Setter Property="Padding"
                Value="10,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            CornerRadius="7"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="Bd"
                                    Property="Opacity"
                                    Value="0.75" />
                        </Trigger>
                        <Trigger Property="IsPressed"
                                 Value="True">
                            <Setter TargetName="Bd"
                                    Property="Opacity"
                                    Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
