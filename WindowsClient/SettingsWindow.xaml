<Window x:Class="AiMonitorClient.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — Ai Monitor Client"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize" WindowStyle="ToolWindow"
        Background="{DynamicResource WindowBg}"
        WindowStartupLocation="CenterOwner">

  <StackPanel Margin="20">

    <TextBlock Text="REMOTE HOST" Style="{StaticResource SectionLabel}"/>

    <!-- Host -->
    <TextBlock Text="Mac computer name or IP address"
               FontSize="11" Foreground="{DynamicResource TextSecondary}"
               Margin="0,0,0,4"/>
    <TextBox x:Name="HostBox"
             FontFamily="Consolas" FontSize="13"
             Padding="8,6" Margin="0,0,0,12"
             Background="{DynamicResource SurfacePanel}"
             Foreground="{DynamicResource TextPrimary}"
             BorderBrush="{DynamicResource CardBorder}"
             BorderThickness="1"
             CaretBrush="{DynamicResource TextPrimary}"/>

    <!-- Port -->
    <TextBlock Text="API Port (default 9876)"
               FontSize="11" Foreground="{DynamicResource TextSecondary}"
               Margin="0,0,0,4"/>
    <TextBox x:Name="PortBox"
             FontFamily="Consolas" FontSize="13"
             Padding="8,6" Margin="0,0,0,20"
             Background="{DynamicResource SurfacePanel}"
             Foreground="{DynamicResource TextPrimary}"
             BorderBrush="{DynamicResource CardBorder}"
             BorderThickness="1"
             CaretBrush="{DynamicResource TextPrimary}"/>

    <TextBlock Text="POLLING INTERVAL" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
    <ComboBox x:Name="PollBox"
              FontFamily="Consolas" FontSize="13"
              Padding="8,6" Margin="0,0,0,20"
              Background="{DynamicResource SurfacePanel}"
              Foreground="{DynamicResource TextPrimary}"
              BorderBrush="{DynamicResource CardBorder}"
              BorderThickness="1">
      <ComboBoxItem Content="300ms"  Tag="300"/>
      <ComboBoxItem Content="500ms"  Tag="500"/>
      <ComboBoxItem Content="1 sec"  Tag="1000"/>
      <ComboBoxItem Content="2 sec"  Tag="2000"/>
      <ComboBoxItem Content="5 sec"  Tag="5000"/>
    </ComboBox>

    <!-- Hint -->
    <TextBlock FontFamily="Consolas" FontSize="9"
               Foreground="{DynamicResource TextSubtle}"
               TextWrapping="Wrap" Margin="0,0,0,20">
      On the Mac, find the IP in System Settings → Network.
      Make sure Ai Monitor is running there (badge shows API port).
    </TextBlock>

    <!-- Buttons -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" Width="80" Height="32" Margin="0,0,8,0"
              Style="{StaticResource ActionBtn}"
              Background="{DynamicResource SurfacePanel}"
              BorderBrush="{DynamicResource CardBorder}"
              Foreground="{DynamicResource TextSecondary}"
              Click="Cancel_Click"/>
      <Button Content="Save" Width="80" Height="32"
              Style="{StaticResource ActionBtn}"
              Click="Save_Click">
        <Button.Background>
          <SolidColorBrush Color="#228BBFFF"/>
        </Button.Background>
        <Button.BorderBrush>
          <SolidColorBrush Color="#558BBFFF"/>
        </Button.BorderBrush>
        <Button.Foreground>
          <SolidColorBrush Color="#8BBFFF"/>
        </Button.Foreground>
      </Button>
    </StackPanel>

  </StackPanel>
</Window>
